{
  "name": "create-scottish-ai-guy-app",
  "version": "1.0.0",
  "description": "Interactive Next.js starter generator for the Scottish AI Guy stack.",
  "type": "module",
  "bin": {
    "create-scottish-ai-guy-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "create",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "starter",
    "generator",
    "cli",
    "scottish-ai-guy",
    "convex",
    "clerk",
    "stripe",
    "mdx"
  ],
  "author": "Scottish AI Guy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottishaiguy/starter.git"
  },
  "homepage": "https://github.com/scottishaiguy/starter#readme",
  "bugs": {
    "url": "https://github.com/scottishaiguy/starter/issues"
  },
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@inquirer/prompts": "^7.6.0",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.0",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.13",
    "eslint": "^9.31.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
